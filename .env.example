# Admin dashboard — set a strong token for /admin review
ADMIN_TOKEN=change-me-in-production

# Email notifications on new applications (optional — uses Resend)
# Sends admin alert + applicant confirmation on apply; status updates when admin reviews
# RESEND_API_KEY=re_...
# NOTIFY_EMAIL=team@sikachain.com
# NOTIFY_FROM=SikaChain <onboarding@sikachain.com>

# Optional: enable LLM-powered AI concierge (falls back to local knowledge base if unset)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Local Spring node RPC for network status widget
SIKACHAIN_RPC_URL=http://127.0.0.1:8888

# Public site URL for sitemap/robots (production)
NEXT_PUBLIC_SITE_URL=http://localhost:3004

# Sika App dev URL (local monorepo default :3003)
NEXT_PUBLIC_SIKA_APP_URL=http://127.0.0.1:3003

# Production deploy: use a public RPC (Vercel cannot reach localhost)
# SIKACHAIN_RPC_URL=https://rpc.sikachain.com

# Production storage — Vercel Blob (auto-created when you add Blob store in Vercel dashboard)
# Without this token, applications save to local data/ (dev only — not persistent on Vercel)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
