{
  "name": "sikachain-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3004",
    "dev:clean": "rm -rf .next && npm run dev",
    "build": "next build",
    "start": "next start -p 3004",
    "lint": "next lint",
    "deploy": "npx vercel --prod",
    "deploy:preview": "npx vercel",
    "sync:chain": "node scripts/sync-chain-config.mjs",
    "dev:stack": "bash scripts/dev-stack.sh",
    "verify:stack": "bash scripts/verify-stack.sh",
    "verify:dev": "bash ../AntelopeOS/spring/sikachaindev/scripts/quick-verify.sh",
    "verify:dev:full": "bash ../AntelopeOS/spring/sikachaindev/scripts/verify-stack.sh",
    "verify:launch-ready": "bash ../AntelopeOS/spring/sikachaindev/scripts/check-launch-ready.sh",
    "verify:gh-v1": "bash ../AntelopeOS/spring/sikachaindev/scripts/verify-gh-v1.sh",
    "verify:predeploy": "bash ../AntelopeOS/spring/sikachaindev/scripts/verify-predeploy.sh",
    "verify:predeploy:gh-v1": "GH_V1=1 bash ../AntelopeOS/spring/sikachaindev/scripts/verify-predeploy.sh",
    "verify:predeploy:full": "FULL=1 bash ../AntelopeOS/spring/sikachaindev/scripts/verify-predeploy.sh"
  },
  "dependencies": {
    "@vercel/blob": "^2.4.1",
    "framer-motion": "^12.40.0",
    "next": "^15.5.19",
    "next-intl": "^4.13.0",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
